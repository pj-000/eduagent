{
  "mcpServers": {
    "eduagent-lesson-plan": {
      "command": "/Users/sss/miniconda3/envs/eduagent/bin/python",
      "args": [
        "scripts/lesson_plan_mcp.py"
      ],
      "cwd": "/Users/sss/directionai/eduagent"
    },
    "eduagent-exam": {
      "command": "/Users/sss/miniconda3/envs/eduagent/bin/python",
      "args": [
        "scripts/exam_mcp.py"
      ],
      "cwd": "/Users/sss/directionai/eduagent"
    },
    "eduagent-ppt": {
      "command": "/Users/sss/miniconda3/envs/eduagent/bin/python",
      "args": [
        "scripts/ppt_mcp.py"
      ],
      "cwd": "/Users/sss/directionai/eduagent"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PERSONAL_ACCESS_TOKEN"
      }
    }
  }
}
